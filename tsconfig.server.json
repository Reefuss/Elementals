{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "@shared/*": ["./src/lib/*"]
    }
  },
  "include": ["server/**/*.ts", "src/lib/game/**/*.ts", "src/lib/socket/events.ts"],
  "exclude": ["node_modules", "src/app", "src/components", "src/hooks", "src/store"]
}
